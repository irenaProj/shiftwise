{
  "name": "ShiftWise Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  // Install PostgreSQL as a feature — no external DB needed in Codespaces
  "features": {
    "ghcr.io/devcontainers/features/postgresql:1": {
      "version": "16"
    }
  },

  // VS Code extensions auto-installed when Codespace starts
  "customizations": {
    "vscode": {
      "extensions": [
        "prisma.prisma",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.preferences.importModuleSpecifier": "relative"
      }
    }
  },

  // Ports to forward automatically
  "forwardPorts": [3001, 5173, 5432],
  "portsAttributes": {
    "3001": { "label": "API (Express)", "onAutoForward": "silent" },
    "5173": { "label": "Frontend (Vite)", "onAutoForward": "openBrowser" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },

  // Runs once when the Codespace container is first created
  "onCreateCommand": "npm install",

  // Runs every time the Codespace starts (including after rebuilds)
  "postStartCommand": "bash .devcontainer/setup.sh"
}
